{
    "$schema": "https://opencode.ai/config.json",
    "lsp": true, 
    "enabled_providers": [ "llama-cpp" ],
    "provider": {
        "llama-cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://giratina.local:8080/v1",
                "apiKey": "not-needed-for-local"
            },
            "models": {
                "local-model": {
                    "name": "Qwen3.6 (llama.cpp)",
                    "limit": {
                        "context": 131072,
                        "output": 16384
                    }
                }
            }
        }
    },
    "agent": {
        "build": {
            "model": "llama-cpp/local-model",
            "temperature": 0.6
        },
        "plan": {
            "model": "llama-cpp/local-model",
            "temperature": 0.3
        }
    },
    "compaction": {
        "threshould": 0.60,
        "strategy": "summarize",
        "preserveRecentMessages": 8
    },
    "watcher": {
        "ignore": [
            "*.csv",
            "*.db",
            "*.json",
            "*.log",
            "*.sqlite",
            "*.tmp",
            ".git/",
            ".mypy_cache/",
            ".next/",
            ".pytest_cache/",
            ".ruff_cache/",
            ".venv/",
            "__pycache__/",
            "build/",
            "coverage/",
            "dist/",
            "node_modules/",
            "target/",
            "venv/"
        ]
    }
}
