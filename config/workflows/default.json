{
  "name": "default",
  "version": "1.0.0",
  "stages": [
    {
      "id": "plan",
      "description": "Prepare RAG context and memory injection",
      "timeout_sec": 30,
      "retryable": false
    },
    {
      "id": "execute",
      "description": "LLM call and tool execution loop",
      "timeout_sec": 120,
      "retryable": true
    },
    {
      "id": "verify",
      "description": "Result validation and loop guard check",
      "timeout_sec": 10,
      "retryable": false
    },
    {
      "id": "retry",
      "description": "Transport error retry gate",
      "timeout_sec": 5,
      "retryable": false
    }
  ],
  "retry_policy": {
    "max_attempts": 3,
    "backoff": "fixed",
    "backoff_sec": 1
  }
}
