{
  "name": "default",
  "version": "1.0.0",
  "stages": [
    {
      "id": "plan",
      "timeout_sec": 30,
      "retryable": false
    },
    {
      "id": "execute",
      "timeout_sec": 120,
      "retryable": true
    },
    {
      "id": "verify",
      "timeout_sec": 10,
      "retryable": false
    }
  ],
  "retry_policy": {
    "max_attempts": 3,
    "backoff_sec": 1
  }
}
