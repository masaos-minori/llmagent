#!/bin/bash
# Embedding LLM server (multilingual-E5-small) on :8003 — subprocess managed by agent

exec /opt/llm/llama.cpp/build/bin/llama-server \
    --model /opt/llm/models/multilingual-E5-small.gguf \
    --host 127.0.0.1 \
    --port 8003 \
    --ctx-size 512 \
    --batch-size 512 \
    --ubatch-size 512 \
    --threads 4 \
    --embeddings \
    --pooling mean \
    >> /opt/llm/logs/embed-llm.log 2>&1
