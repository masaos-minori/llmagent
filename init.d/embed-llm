#!/sbin/openrc-run
# 埋込 LLM: multilingual-E5-small を port 8003 で起動する

description="Embedding LLM server (multilingual-E5-small) on :8003"

command="/opt/llm/llama.cpp/build/bin/llama-server"
command_args="
    --model /opt/llm/models/multilingual-E5-small.gguf
    --host 127.0.0.1
    --port 8003
    --ctx-size 512
    --batch-size 512
    --ubatch-size 512
    --threads 4
    --embeddings
    --pooling mean"
command_background=true
pidfile="/run/${RC_SVCNAME}.pid"
output_log="/opt/llm/logs/embed-llm.log"
error_log="/opt/llm/logs/embed-llm.log"

depend() {
    need net
}
