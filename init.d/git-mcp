#!/sbin/openrc-run
# git-mcp: local git operations MCP server (FastAPI/Uvicorn :8014) の OpenRC 起動スクリプト
# 最小権限原則に従い llm-agent (非 root) ユーザで実行する

description="Local Git Operations MCP Server (FastAPI/Uvicorn :8014)"

command="/opt/llm/venv/bin/uvicorn"
command_args="mcp.git.server:app --host 127.0.0.1 --port 8014 --workers 1"
command_background="yes"
# 専用非 root ユーザで起動する
command_user="llm-agent"

directory="/opt/llm/scripts"

pidfile="/run/${RC_SVCNAME}.pid"
output_log="/opt/llm/logs/git-mcp.log"
error_log="/opt/llm/logs/git-mcp.log"

depend() {
    need net
}

start_pre() {
    checkpath --directory --owner root:root --mode 0755 /opt/llm/logs
}
